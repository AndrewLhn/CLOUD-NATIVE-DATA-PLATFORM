{
  "name": "s3-sink-pageviews",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",
    "topics": "pageviews",
    "s3.bucket.name": "telemetry-bronze",
    "s3.region": "us-east-1",
    "aws.access.key.id": "admin",
    "aws.secret.access.key": "supersecretpassword123",
    "store.url": "minio_storage:9000",
    "store.url.protocol": "http",
    "s3.path.style.access": "true",
    "flush.size": "100",
    "rotate.interval.ms": "60000",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
    "partitioner.class": "io.confluent.connect.storage.partitioner.DefaultPartitioner",
    "schema.compatibility": "NONE",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema_registry:8081",
    "schema.generator.class": "io.confluent.connect.storage.hive.schema.DefaultSchemaGenerator"
  }
}